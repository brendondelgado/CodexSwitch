#!/usr/bin/env zsh
set -e
setopt NO_BG_NICE

DEFAULT_THREAD_ID="019ddf25-8e5d-7d93-9006-54488876f0fa"
THREAD_ID_FILE="${HOME}/.codexswitch/codex-vps-thread-id"
THREAD_ID="${CODEX_VPS_THREAD_ID:-$(cat "$THREAD_ID_FILE" 2>/dev/null || printf "%s" "$DEFAULT_THREAD_ID")}"
LOCAL_PORT="${CODEX_VPS_LOCAL_PORT:-18390}"
REMOTE_PORT="8390"
REMOTE_HOST="${CODEX_VPS_REMOTE_HOST:-signul@100.95.84.123}"
TAILSCALE_HOST="${CODEX_VPS_TAILSCALE_HOST:-signul-hostinger-kvm4}"
TAILSCALE_TARGET="signul@${TAILSCALE_HOST}"
TAILSCALE_BIN="/Applications/Tailscale.app/Contents/MacOS/Tailscale"
LOCAL_REPO="${CODEX_VPS_LOCAL_REPO:-${HOME}/SIGNUL}"
REMOTE_REPO="${CODEX_VPS_REMOTE_REPO:-/home/signul/SIGNUL}"
SERVICE_NAME="signul-codex-app-server.service"
REMOTE_RELEASE_ROOT="${CODEX_VPS_REMOTE_RELEASE_ROOT:-/home/signul/.local/share/codexswitch/current}"
REMOTE_RELEASE_CODEX="${REMOTE_RELEASE_ROOT}/patched-codex/codex"
REMOTE_RELEASE_CLI="${REMOTE_RELEASE_ROOT}/codexswitch-cli"
LOCAL_CLIENT_ROOT="${HOME}/.local/share/codexswitch/remote-client"
PATCHED_REMOTE_CLIENT="${HOME}/.local/share/codexswitch/patched-mac-remote-client/codex"
if [[ -x "/Applications/ChatGPT.app/Contents/Resources/codex" ]]; then
  APP_BUNDLED_CLIENT="/Applications/ChatGPT.app/Contents/Resources/codex"
else
  APP_BUNDLED_CLIENT="/Applications/Codex.app/Contents/Resources/codex"
fi
NPM_REMOTE_CLIENT="${LOCAL_CLIENT_ROOT}/node_modules/.bin/codex"
LOCAL_CLIENT="${PATCHED_REMOTE_CLIENT}"
PTY_BRIDGE="${HOME}/.local/bin/codex-vps-pty-bridge"
DESKTOP_REMOTE_PROXY_PATTERN='codex app-server proxy --sock .*desktop-ssh-websocket-v0\.sock'
SSH_BIN="${CODEX_VPS_SSH_BIN:-ssh}"
LSOF_BIN="${CODEX_VPS_LSOF_BIN:-lsof}"
CURL_BIN="${CODEX_VPS_CURL_BIN:-/usr/bin/curl}"
PS_BIN="${CODEX_VPS_PS_BIN:-ps}"
ID_BIN="${CODEX_VPS_ID_BIN:-/usr/bin/id}"
STAT_BIN="${CODEX_VPS_STAT_BIN:-/usr/bin/stat}"
KILL_BIN="${CODEX_VPS_KILL_BIN:-kill}"
SLEEP_BIN="${CODEX_VPS_SLEEP_BIN:-sleep}"
SSH_CONNECT_TIMEOUT="${CODEX_VPS_SSH_CONNECT_TIMEOUT:-30}"
SSH_SERVER_ALIVE_INTERVAL="${CODEX_VPS_SSH_SERVER_ALIVE_INTERVAL:-15}"
SSH_SERVER_ALIVE_COUNT_MAX="${CODEX_VPS_SSH_SERVER_ALIVE_COUNT_MAX:-6}"
SSH_PROBE_TIMEOUT="${CODEX_VPS_SSH_PROBE_TIMEOUT:-40}"
SSH_OPTS=(
  -F /dev/null
  -o BatchMode=yes
  -o "ConnectTimeout=${SSH_CONNECT_TIMEOUT}"
  -o "ServerAliveInterval=${SSH_SERVER_ALIVE_INTERVAL}"
  -o "ServerAliveCountMax=${SSH_SERVER_ALIVE_COUNT_MAX}"
  -o ControlMaster=no
  -o ControlPath=none
  -o ControlPersist=no
  -o IdentityFile="${HOME}/.ssh/id_ed25519"
  -o IdentitiesOnly=yes
)
SSH_PROXY_OPTS=(
  -o BatchMode=yes
  -o "ConnectTimeout=${SSH_CONNECT_TIMEOUT}"
  -o "ServerAliveInterval=${SSH_SERVER_ALIVE_INTERVAL}"
  -o "ServerAliveCountMax=${SSH_SERVER_ALIVE_COUNT_MAX}"
  -o ControlMaster=no
  -o ControlPath=none
  -o ControlPersist=no
  -o StrictHostKeyChecking=accept-new
  -o "ProxyCommand=${TAILSCALE_BIN} nc %h %p"
)
TUNNEL_SSH_OPTS=(
  "${SSH_OPTS[@]}"
)
TUNNEL_SSH_PROXY_OPTS=(
  "${SSH_PROXY_OPTS[@]}"
)
USE_TAILSCALE_PROXY=0
HEALTH_URL="http://127.0.0.1:${LOCAL_PORT}/healthz"
DIRECT_TAILSCALE_HOST="100.95.84.123"
DIRECT_REMOTE_URL="ws://${DIRECT_TAILSCALE_HOST}:${REMOTE_PORT}"
DIRECT_HEALTH_URL="http://${DIRECT_TAILSCALE_HOST}:${REMOTE_PORT}/healthz"
REMOTE_URL="ws://127.0.0.1:${LOCAL_PORT}"
USE_DIRECT_TAILSCALE_APP_SERVER=0
TUNNEL_SUPERVISOR_PID=""
TUNNEL_SSH_PID=""
TUNNEL_OWNER_PID=""
TUNNEL_OWNER_TOKEN=""
TUNNEL_LOCK_HELD=0
TUNNEL_LOCK_DIR="${CODEX_VPS_TUNNEL_LOCK_DIR:-${HOME}/.codexswitch/codex-vps-tunnel-${LOCAL_PORT}.lock}"
TUNNEL_METADATA_FILE="${TUNNEL_LOCK_DIR}/owner"
if [ -n "${CODEX_VPS_HELPER_PATH:-}" ]; then
  HELPER_PATH="${CODEX_VPS_HELPER_PATH:A}"
elif [ -n "${CODEX_VPS_SCRIPT_PATH:-}" ]; then
  HELPER_PATH="${CODEX_VPS_SCRIPT_PATH:A}"
else
  HELPER_PATH="${0:A}"
fi
TUNNEL_HEALTH_TIMEOUT_SECONDS="${CODEX_VPS_TUNNEL_HEALTH_TIMEOUT_SECONDS:-8}"
TUNNEL_HEALTH_FAILURE_LIMIT="${CODEX_VPS_TUNNEL_HEALTH_FAILURE_LIMIT:-4}"
TUNNEL_HEALTH_INTERVAL_SECONDS="${CODEX_VPS_TUNNEL_HEALTH_INTERVAL_SECONDS:-2}"
TUNNEL_STARTUP_TIMEOUT_SECONDS="${CODEX_VPS_TUNNEL_STARTUP_TIMEOUT_SECONDS:-90}"
TUNNEL_RECONNECT_DELAY="${CODEX_VPS_TUNNEL_RECONNECT_DELAY:-2}"
TUNNEL_RECONNECT_DELAY_MAX="${CODEX_VPS_TUNNEL_RECONNECT_DELAY_MAX:-30}"
TUNNEL_SUPERVISOR_MAX_ITERATIONS="${CODEX_VPS_TEST_TUNNEL_SUPERVISOR_MAX_ITERATIONS:-0}"
TUNNEL_CLEANUP_ACTIVE=0
REMOTE_DISK_WARN_USED_PERCENT="${CODEX_VPS_REMOTE_DISK_WARN_USED_PERCENT:-90}"
REMOTE_DISK_FAIL_USED_PERCENT="${CODEX_VPS_REMOTE_DISK_FAIL_USED_PERCENT:-97}"
REMOTE_DISK_MIN_FREE_MB="${CODEX_VPS_REMOTE_DISK_MIN_FREE_MB:-20480}"
REMOTE_CLIENT_AUTO_RECONNECT="${CODEX_VPS_AUTO_RECONNECT:-1}"
REMOTE_CLIENT_RECONNECT_DELAY="${CODEX_VPS_RECONNECT_DELAY:-2}"
REMOTE_CLIENT_RECONNECT_DELAY_MAX="${CODEX_VPS_RECONNECT_DELAY_MAX:-30}"
REMOTE_CLIENT_RECONNECT_MAX="${CODEX_VPS_RECONNECT_MAX:-0}"
REMOTE_VERSION_SNAPSHOT=""
LOCAL_CLIENT_VERSION_SNAPSHOT=""

log() {
  echo "codex-vps: $*" >&2
}

is_nonnegative_integer() {
  case "$1" in
    ""|*[!0-9]*) return 1 ;;
    *) return 0 ;;
  esac
}

is_positive_integer() {
  is_nonnegative_integer "$1" && [ "$1" -gt 0 ]
}

is_valid_thread_id() {
  local pattern='^[[:xdigit:]]{8}-[[:xdigit:]]{4}-[[:xdigit:]]{4}-[[:xdigit:]]{4}-[[:xdigit:]]{12}$'
  [[ "${1:-}" =~ $pattern ]]
}

require_valid_thread_id() {
  local value="${1:-}"
  local source="${2:-thread id}"
  if ! is_valid_thread_id "$value"; then
    echo "codex-vps: invalid ${source}; expected a canonical UUID" >&2
    return 2
  fi
}

validate_thread_command_args() {
  case "${1:-}" in
    help|-h|--help|--check|start|sync-client|create|new|reset|old|legacy|restart|--restart|restart-connect|--restart-connect)
      return 0
      ;;
    resume|use|archive)
      require_valid_thread_id "${2:-}" "thread id"
      ;;
    *)
      require_valid_thread_id "$THREAD_ID" "configured thread id"
      ;;
  esac
}

print_usage() {
  cat <<'EOF'
usage: codex-vps [command]

commands:
  codex-vps              connect to the default VPS thread
  codex-vps create       create a fresh VPS thread and make it default without connecting
  codex-vps new          create a fresh VPS thread, make it default, and connect
  codex-vps reset        alias for new
  codex-vps list         list visible VPS app-server threads
  codex-vps resume <id>  set <id> as default and connect to it
  codex-vps use <id>     set <id> as default without connecting
  codex-vps old          restore the original giant thread as default
  codex-vps archive <id> archive a visible thread in the app-server
  codex-vps --check      inspect transport, service, and client readiness without repair
  codex-vps start        explicitly start the port-8390 VPS app-server
  codex-vps restart      explicitly restart the VPS app-server and desktop bridge
  codex-vps sync-client  explicitly install the matching Mac remote client
EOF
}

persist_default_thread_id() {
  local thread_id="$1"
  local directory tmp
  require_valid_thread_id "$thread_id" "thread id" || return $?
  directory="${THREAD_ID_FILE:h}"
  tmp="${THREAD_ID_FILE}.tmp.$$"
  mkdir -p "$directory"
  chmod 700 "$directory" 2>/dev/null || true
  printf '%s\n' "$thread_id" > "$tmp"
  chmod 600 "$tmp"
  mv -f "$tmp" "$THREAD_ID_FILE"
}

validate_runtime_config() {
  local name value
  for name value in \
    CODEX_VPS_SSH_CONNECT_TIMEOUT "$SSH_CONNECT_TIMEOUT" \
    CODEX_VPS_SSH_SERVER_ALIVE_INTERVAL "$SSH_SERVER_ALIVE_INTERVAL" \
    CODEX_VPS_SSH_SERVER_ALIVE_COUNT_MAX "$SSH_SERVER_ALIVE_COUNT_MAX" \
    CODEX_VPS_SSH_PROBE_TIMEOUT "$SSH_PROBE_TIMEOUT" \
    CODEX_VPS_TUNNEL_HEALTH_TIMEOUT_SECONDS "$TUNNEL_HEALTH_TIMEOUT_SECONDS" \
    CODEX_VPS_TUNNEL_HEALTH_FAILURE_LIMIT "$TUNNEL_HEALTH_FAILURE_LIMIT" \
    CODEX_VPS_TUNNEL_HEALTH_INTERVAL_SECONDS "$TUNNEL_HEALTH_INTERVAL_SECONDS" \
    CODEX_VPS_TUNNEL_STARTUP_TIMEOUT_SECONDS "$TUNNEL_STARTUP_TIMEOUT_SECONDS" \
    CODEX_VPS_TUNNEL_RECONNECT_DELAY "$TUNNEL_RECONNECT_DELAY" \
    CODEX_VPS_TUNNEL_RECONNECT_DELAY_MAX "$TUNNEL_RECONNECT_DELAY_MAX" \
    CODEX_VPS_RECONNECT_DELAY "$REMOTE_CLIENT_RECONNECT_DELAY" \
    CODEX_VPS_RECONNECT_DELAY_MAX "$REMOTE_CLIENT_RECONNECT_DELAY_MAX"; do
    if ! is_positive_integer "$value"; then
      echo "codex-vps: ${name} must be a positive integer (got '${value}')" >&2
      return 2
    fi
  done

  if ! is_nonnegative_integer "$REMOTE_CLIENT_RECONNECT_MAX"; then
    echo "codex-vps: CODEX_VPS_RECONNECT_MAX must be a nonnegative integer (got '${REMOTE_CLIENT_RECONNECT_MAX}')" >&2
    return 2
  fi
}

current_process_pid() {
  zmodload zsh/system 2>/dev/null || true
  # Every caller captures this function with $(...), so the command-substitution
  # process reports its parent: the shell that actually owns the child/lock.
  printf '%s' "${sysparams[ppid]:-$$}"
}

process_is_alive() {
  local pid="$1"
  local state
  [ -n "$pid" ] && "$KILL_BIN" -0 "$pid" >/dev/null 2>&1 || return 1
  state="$("$PS_BIN" -p "$pid" -o stat= 2>/dev/null | tr -d '[:space:]')"
  [[ -z "$state" || "$state" != Z* ]]
}

current_uid() {
  "$ID_BIN" -u 2>/dev/null | tr -d '[:space:]'
}

process_identity_value() {
  local pid="$1"
  local field="$2"
  local value
  value="$("$PS_BIN" -p "$pid" -o "${field}=" 2>/dev/null)" || return 1
  printf '%s\n' "$value" | awk '{$1=$1; print}'
}

process_uid() {
  process_identity_value "$1" uid
}

process_executable_identity() {
  process_identity_value "$1" comm
}

process_start_identity() {
  process_identity_value "$1" lstart
}

path_owner_uid() {
  local path="$1"
  local value
  if value="$("$STAT_BIN" -f '%u' "$path" 2>/dev/null)" && is_nonnegative_integer "$value"; then
    printf '%s' "$value"
    return 0
  fi
  "$STAT_BIN" -c '%u' "$path" 2>/dev/null
}

path_permission_mode() {
  local path="$1"
  local value
  if value="$("$STAT_BIN" -f '%Lp' "$path" 2>/dev/null)" && is_nonnegative_integer "$value"; then
    printf '%s' "$value"
    return 0
  fi
  "$STAT_BIN" -c '%a' "$path" 2>/dev/null
}

sleep_for() {
  "$SLEEP_BIN" "$1"
}

reconnect_delay_for_attempt() {
  local attempt="$1"
  local delay="$2"
  local maximum="$3"
  local index=1

  while [ "$index" -lt "$attempt" ] && [ "$delay" -lt "$maximum" ]; do
    delay=$((delay * 2))
    if [ "$delay" -gt "$maximum" ]; then
      delay="$maximum"
    fi
    index=$((index + 1))
  done
  printf '%s' "$delay"
}

tunnel_listener_pids() {
  "$LSOF_BIN" -tiTCP:${LOCAL_PORT} -sTCP:LISTEN 2>/dev/null | awk 'NF && !seen[$0]++'
}

tunnel_metadata_value() {
  local key="$1"
  [ -f "$TUNNEL_METADATA_FILE" ] || return 1
  awk -F= -v key="$key" '$1 == key { sub(/^[^=]*=/, ""); print; exit }' "$TUNNEL_METADATA_FILE"
}

tunnel_metadata_has_exact_schema() {
  [ -f "$TUNNEL_METADATA_FILE" ] && [ ! -L "$TUNNEL_METADATA_FILE" ] || return 1
  awk -F= '
    BEGIN {
      expected["version"] = 1
      expected["helper_path"] = 1
      expected["owner_pid"] = 1
      expected["owner_token"] = 1
      expected["owner_uid"] = 1
      expected["owner_executable"] = 1
      expected["owner_start"] = 1
      expected["supervisor_pid"] = 1
      expected["supervisor_uid"] = 1
      expected["supervisor_executable"] = 1
      expected["supervisor_start"] = 1
      expected["ssh_pid"] = 1
      expected["ssh_uid"] = 1
      expected["ssh_executable"] = 1
      expected["ssh_start"] = 1
      expected["local_port"] = 1
      expected["remote_port"] = 1
      expected["remote_host"] = 1
    }
    !($1 in expected) || seen[$1]++ { exit 1 }
    END {
      for (key in expected) {
        if (seen[key] != 1) exit 1
      }
    }
  ' "$TUNNEL_METADATA_FILE"
}

tunnel_metadata_owner_mode_ok() {
  local uid metadata_uid metadata_mode lock_uid lock_mode
  uid="$(current_uid)"
  is_nonnegative_integer "$uid" || return 1
  metadata_uid="$(path_owner_uid "$TUNNEL_METADATA_FILE" 2>/dev/null || true)"
  metadata_mode="$(path_permission_mode "$TUNNEL_METADATA_FILE" 2>/dev/null || true)"
  lock_uid="$(path_owner_uid "$TUNNEL_LOCK_DIR" 2>/dev/null || true)"
  lock_mode="$(path_permission_mode "$TUNNEL_LOCK_DIR" 2>/dev/null || true)"
  [ "$metadata_uid" = "$uid" ] && [ "$lock_uid" = "$uid" ] || return 1
  [[ "$metadata_mode" = 600 || "$metadata_mode" = 0600 ]] || return 1
  [[ "$lock_mode" = 700 || "$lock_mode" = 0700 ]]
}

recorded_tunnel_owner_metadata_ok() {
  local version helper_path owner_pid owner_token owner_uid owner_executable owner_start
  local expected_uid owner_pattern

  tunnel_metadata_owner_mode_ok || return 1
  tunnel_metadata_has_exact_schema || return 1
  version="$(tunnel_metadata_value version 2>/dev/null || true)"
  helper_path="$(tunnel_metadata_value helper_path 2>/dev/null || true)"
  owner_pid="$(tunnel_metadata_value owner_pid 2>/dev/null || true)"
  owner_token="$(tunnel_metadata_value owner_token 2>/dev/null || true)"
  owner_uid="$(tunnel_metadata_value owner_uid 2>/dev/null || true)"
  owner_executable="$(tunnel_metadata_value owner_executable 2>/dev/null || true)"
  owner_start="$(tunnel_metadata_value owner_start 2>/dev/null || true)"
  expected_uid="$(current_uid)"

  [ "$version" = "3" ] && [ "$helper_path" = "$HELPER_PATH" ] || return 1
  [ "$(tunnel_metadata_value local_port 2>/dev/null || true)" = "$LOCAL_PORT" ] || return 1
  [ "$(tunnel_metadata_value remote_port 2>/dev/null || true)" = "$REMOTE_PORT" ] || return 1
  [ "$(tunnel_metadata_value remote_host 2>/dev/null || true)" = "$REMOTE_HOST" ] || return 1
  is_positive_integer "$owner_pid" || return 1
  is_nonnegative_integer "$expected_uid" && [ "$owner_uid" = "$expected_uid" ] || return 1
  [ -n "$owner_executable" ] && [ -n "$owner_start" ] || return 1
  owner_pattern="^${owner_pid}-[0-9]+-[0-9]+-[0-9]+$"
  [[ "$owner_token" =~ $owner_pattern ]]
}

metadata_process_evidence_matches() {
  local prefix="$1"
  local pid="$2"
  local uid executable start expected_uid
  expected_uid="$(current_uid)"
  uid="$(tunnel_metadata_value "${prefix}_uid" 2>/dev/null || true)"
  executable="$(tunnel_metadata_value "${prefix}_executable" 2>/dev/null || true)"
  start="$(tunnel_metadata_value "${prefix}_start" 2>/dev/null || true)"
  [ "$uid" = "$expected_uid" ] && [ -n "$executable" ] && [ -n "$start" ] || return 1
  process_is_alive "$pid" || return 1
  [ "$(process_uid "$pid" 2>/dev/null || true)" = "$uid" ] || return 1
  [ "$(process_executable_identity "$pid" 2>/dev/null || true)" = "$executable" ] || return 1
  [ "$(process_start_identity "$pid" 2>/dev/null || true)" = "$start" ]
}

tunnel_metadata_matches_current_owner() {
  [ "$TUNNEL_LOCK_HELD" = "1" ] && recorded_tunnel_owner_metadata_ok &&
    [ "$(tunnel_metadata_value owner_pid 2>/dev/null || true)" = "$TUNNEL_OWNER_PID" ] &&
    [ "$(tunnel_metadata_value owner_token 2>/dev/null || true)" = "$TUNNEL_OWNER_TOKEN" ] &&
    metadata_process_evidence_matches owner "$TUNNEL_OWNER_PID"
}

write_tunnel_metadata() {
  local supervisor_pid="${1:-}"
  local ssh_pid="${2:-}"
  local writer_pid temp_file uid
  local owner_uid owner_executable owner_start
  local supervisor_uid="" supervisor_executable="" supervisor_start=""
  local ssh_uid="" ssh_executable="" ssh_start=""

  [ "$TUNNEL_LOCK_HELD" = "1" ] || return 1
  uid="$(current_uid)"
  is_nonnegative_integer "$uid" || return 1
  owner_uid="$(process_uid "$TUNNEL_OWNER_PID")" || return 1
  owner_executable="$(process_executable_identity "$TUNNEL_OWNER_PID")" || return 1
  owner_start="$(process_start_identity "$TUNNEL_OWNER_PID")" || return 1
  [ "$owner_uid" = "$uid" ] && [ -n "$owner_executable" ] && [ -n "$owner_start" ] || return 1
  if [ -n "$supervisor_pid" ]; then
    supervisor_uid="$(process_uid "$supervisor_pid")" || return 1
    supervisor_executable="$(process_executable_identity "$supervisor_pid")" || return 1
    supervisor_start="$(process_start_identity "$supervisor_pid")" || return 1
    [ "$supervisor_uid" = "$uid" ] && [ -n "$supervisor_executable" ] && [ -n "$supervisor_start" ] || return 1
  fi
  if [ -n "$ssh_pid" ]; then
    ssh_uid="$(process_uid "$ssh_pid")" || return 1
    ssh_executable="$(process_executable_identity "$ssh_pid")" || return 1
    ssh_start="$(process_start_identity "$ssh_pid")" || return 1
    [ "$ssh_uid" = "$uid" ] && [ -n "$ssh_executable" ] && [ -n "$ssh_start" ] || return 1
  fi
  writer_pid="$(current_process_pid)"
  temp_file="${TUNNEL_METADATA_FILE}.tmp.${writer_pid}.${RANDOM}"
  umask 077
  {
    printf 'version=3\n'
    printf 'helper_path=%s\n' "$HELPER_PATH"
    printf 'owner_pid=%s\n' "$TUNNEL_OWNER_PID"
    printf 'owner_token=%s\n' "$TUNNEL_OWNER_TOKEN"
    printf 'owner_uid=%s\n' "$owner_uid"
    printf 'owner_executable=%s\n' "$owner_executable"
    printf 'owner_start=%s\n' "$owner_start"
    printf 'supervisor_pid=%s\n' "$supervisor_pid"
    printf 'supervisor_uid=%s\n' "$supervisor_uid"
    printf 'supervisor_executable=%s\n' "$supervisor_executable"
    printf 'supervisor_start=%s\n' "$supervisor_start"
    printf 'ssh_pid=%s\n' "$ssh_pid"
    printf 'ssh_uid=%s\n' "$ssh_uid"
    printf 'ssh_executable=%s\n' "$ssh_executable"
    printf 'ssh_start=%s\n' "$ssh_start"
    printf 'local_port=%s\n' "$LOCAL_PORT"
    printf 'remote_port=%s\n' "$REMOTE_PORT"
    printf 'remote_host=%s\n' "$REMOTE_HOST"
  } > "$temp_file"
  mv -f "$temp_file" "$TUNNEL_METADATA_FILE"
  chmod 600 "$TUNNEL_METADATA_FILE"
}

refuse_unknown_tunnel_listener() {
  local pids
  pids="$(tunnel_listener_pids || true)"
  [ -n "$pids" ] || return 0
  log "refusing listener on 127.0.0.1:${LOCAL_PORT}; it is not this helper's verified SSH child (PID(s): ${(j:,:)${(f)pids}})"
  return 1
}

acquire_tunnel_lock() {
  local lock_parent existing_owner existing_owner_token stale_lock

  TUNNEL_OWNER_PID="$(current_process_pid)"
  TUNNEL_OWNER_TOKEN="${TUNNEL_OWNER_PID}-${EPOCHSECONDS:-0}-${RANDOM}-${RANDOM}"
  lock_parent="${TUNNEL_LOCK_DIR:h}"
  mkdir -p "$lock_parent"

  if mkdir "$TUNNEL_LOCK_DIR" 2>/dev/null; then
    chmod 700 "$TUNNEL_LOCK_DIR"
    TUNNEL_LOCK_HELD=1
    write_tunnel_metadata "" ""
    return 0
  fi

  if ! recorded_tunnel_owner_metadata_ok; then
    log "refusing tunnel startup; stored owner UID/start-time/executable provenance is invalid; leaving ${TUNNEL_LOCK_DIR} untouched"
    return 1
  fi
  existing_owner="$(tunnel_metadata_value owner_pid 2>/dev/null || true)"
  existing_owner_token="$(tunnel_metadata_value owner_token 2>/dev/null || true)"
  if process_is_alive "$existing_owner"; then
    if ! metadata_process_evidence_matches owner "$existing_owner"; then
      log "refusing tunnel startup; live PID ${existing_owner} does not match stored owner UID/start-time/executable provenance; leaving ${TUNNEL_LOCK_DIR} untouched"
      return 1
    fi
    log "refusing tunnel startup; another verified codex-vps helper owns ${TUNNEL_LOCK_DIR} (PID ${existing_owner})"
    return 1
  fi
  refuse_unknown_tunnel_listener || return 1

  if ! recorded_tunnel_owner_metadata_ok \
    || [ "$(tunnel_metadata_value owner_pid 2>/dev/null || true)" != "$existing_owner" ] \
    || [ "$(tunnel_metadata_value owner_token 2>/dev/null || true)" != "$existing_owner_token" ] \
    || process_is_alive "$existing_owner"; then
    log "refusing tunnel startup; ownership evidence changed while checking stale lock ${TUNNEL_LOCK_DIR}"
    return 1
  fi

  stale_lock="${TUNNEL_LOCK_DIR}.stale.${TUNNEL_OWNER_PID}.${RANDOM}"
  if ! mv "$TUNNEL_LOCK_DIR" "$stale_lock" 2>/dev/null; then
    log "refusing tunnel startup; ownership lock changed while checking it"
    return 1
  fi
  rm -f "${stale_lock}/owner"
  if ! rmdir "$stale_lock" 2>/dev/null; then
    log "warning: stale ownership lock retained at ${stale_lock} for inspection"
  fi

  if ! mkdir "$TUNNEL_LOCK_DIR" 2>/dev/null; then
    log "refusing tunnel startup; another helper acquired the ownership lock"
    return 1
  fi
  chmod 700 "$TUNNEL_LOCK_DIR"
  TUNNEL_LOCK_HELD=1
  write_tunnel_metadata "" ""
}

release_tunnel_lock() {
  [ "$TUNNEL_LOCK_HELD" = "1" ] || return 0
  if tunnel_metadata_matches_current_owner; then
    if [ -n "$(tunnel_listener_pids || true)" ]; then
      log "warning: listener still present on ${LOCAL_PORT}; retaining ownership lock"
      return 1
    fi
    rm -f "$TUNNEL_METADATA_FILE"
    rmdir "$TUNNEL_LOCK_DIR" 2>/dev/null || log "warning: could not remove tunnel ownership lock ${TUNNEL_LOCK_DIR}"
  else
    log "warning: tunnel ownership token changed; leaving lock untouched"
  fi
  TUNNEL_LOCK_HELD=0
}

codex_version() {
  "$1" --version 2>/dev/null | awk '{print $2}'
}

codex_config_value() {
  local key="$1"
  awk -F= -v key="$key" '
    $1 ~ "^[[:space:]]*" key "[[:space:]]*$" {
      value=$2
      sub(/^[[:space:]]+/, "", value)
      sub(/[[:space:]]+$/, "", value)
      gsub(/^"/, "", value)
      gsub(/"$/, "", value)
      print value
      exit
    }
  ' "${HOME}/.codex/config.toml" 2>/dev/null
}

safe_model_value() {
  case "$1" in
    ""|*[!A-Za-z0-9._:-]*) return 1 ;;
    *) return 0 ;;
  esac
}

safe_reasoning_effort_value() {
  case "$1" in
    none|minimal|low|medium|high|xhigh|max|ultra) return 0 ;;
    *) return 1 ;;
  esac
}

codex_launch_config_args() {
  local model="$(codex_launch_model)"
  local effort="$(codex_launch_reasoning_effort)"

  printf '%s\n' "-c" "features.goals=true"

  if safe_model_value "$model"; then
    printf '%s\n' "-c" "model=${model}"
  fi

  if safe_reasoning_effort_value "$effort"; then
    printf '%s\n' "-c" "model_reasoning_effort=${effort}"
  fi

  codex_launch_permission_args
}

codex_remote_shell_config_args() {
  local model="$(codex_launch_model)"
  local effort="$(codex_launch_reasoning_effort)"
  local args="-c features.goals=true"

  if safe_model_value "$model"; then
    args="${args} -c model=${model}"
  fi

  if safe_reasoning_effort_value "$effort"; then
    args="${args} -c model_reasoning_effort=${effort}"
  fi

  local permission_args
  permission_args="$(codex_remote_shell_permission_args)"
  if [ -n "$permission_args" ]; then
    args="${args} ${permission_args}"
  fi

  printf '%s' "$args"
}

direct_ssh_session_command() {
  local remote_args="$1"
  local remote_repo remote_codex
  remote_repo="$(printf '%q' "$REMOTE_REPO")"
  remote_codex="$(printf '%q' "$REMOTE_RELEASE_CODEX")"
  printf 'cd %s && exec %s %s resume %s' \
    "$remote_repo" "$remote_codex" "$remote_args" "$THREAD_ID"
}

codex_launch_model() {
  printf '%s' "${CODEX_VPS_MODEL:-$(codex_config_value model)}"
}

codex_launch_reasoning_effort() {
  printf '%s' "${CODEX_VPS_REASONING_EFFORT:-$(codex_config_value model_reasoning_effort)}"
}

codex_app_thread_permissions_json() {
  /usr/bin/python3 - "$THREAD_ID" "${HOME}/.codex/.codex-global-state.json" <<'PY'
import json, sys
thread_id, path = sys.argv[1], sys.argv[2]
try:
    data = json.load(open(path, "r", encoding="utf-8"))
except Exception:
    raise SystemExit

state = data.get("electron-persisted-atom-state", {})
per_thread = state.get("heartbeat-thread-permissions-by-id", {})
permissions = per_thread.get(thread_id)
if not isinstance(permissions, dict):
    mode = (state.get("agent-mode-by-host-id") or {}).get("remote-ssh-discovered:signul-vps")
    if mode == "full-access":
        permissions = {
            "approvalPolicy": "never",
            "approvalsReviewer": "user",
            "sandboxPolicy": {"type": "dangerFullAccess"},
        }
if isinstance(permissions, dict):
    print(json.dumps(permissions, separators=(",", ":")))
PY
}

codex_launch_permission_args() {
  local permissions approval sandbox
  permissions="$(codex_app_thread_permissions_json 2>/dev/null || true)"
  [ -n "$permissions" ] || return 0
  approval="$(/usr/bin/python3 -c 'import json,sys; print((json.loads(sys.argv[1]).get("approvalPolicy") or ""))' "$permissions" 2>/dev/null || true)"
  sandbox="$(/usr/bin/python3 -c 'import json,sys; print(((json.loads(sys.argv[1]).get("sandboxPolicy") or {}).get("type") or ""))' "$permissions" 2>/dev/null || true)"

  case "$approval" in
    never|on-request|on-failure|untrusted)
      printf '%s\n' "-c" "approval_policy=${approval}"
      ;;
  esac

  case "$sandbox" in
    dangerFullAccess)
      printf '%s\n' "-c" "sandbox_mode=danger-full-access"
      ;;
    workspaceWrite)
      printf '%s\n' "-c" "sandbox_mode=workspace-write"
      ;;
    readOnly)
      printf '%s\n' "-c" "sandbox_mode=read-only"
      ;;
  esac
}

codex_remote_shell_permission_args() {
  local permissions approval sandbox args
  permissions="$(codex_app_thread_permissions_json 2>/dev/null || true)"
  [ -n "$permissions" ] || return 0
  approval="$(/usr/bin/python3 -c 'import json,sys; print((json.loads(sys.argv[1]).get("approvalPolicy") or ""))' "$permissions" 2>/dev/null || true)"
  sandbox="$(/usr/bin/python3 -c 'import json,sys; print(((json.loads(sys.argv[1]).get("sandboxPolicy") or {}).get("type") or ""))' "$permissions" 2>/dev/null || true)"
  args=""

  case "$approval" in
    never|on-request|on-failure|untrusted)
      args="${args} -c approval_policy=${approval}"
      ;;
  esac

  case "$sandbox" in
    dangerFullAccess)
      args="${args} -c sandbox_mode=danger-full-access"
      ;;
    workspaceWrite)
      args="${args} -c sandbox_mode=workspace-write"
      ;;
    readOnly)
      args="${args} -c sandbox_mode=read-only"
      ;;
  esac

  printf '%s' "$args"
}

codex_launch_permission_summary() {
  local permissions approval sandbox
  permissions="$(codex_app_thread_permissions_json 2>/dev/null || true)"
  [ -n "$permissions" ] || {
    printf 'config'
    return 0
  }
  approval="$(/usr/bin/python3 -c 'import json,sys; print((json.loads(sys.argv[1]).get("approvalPolicy") or "unknown"))' "$permissions" 2>/dev/null || printf 'unknown')"
  sandbox="$(/usr/bin/python3 -c 'import json,sys; print(((json.loads(sys.argv[1]).get("sandboxPolicy") or {}).get("type") or "unknown"))' "$permissions" 2>/dev/null || printf 'unknown')"
  printf 'approval=%s sandbox=%s' "$approval" "$sandbox"
}

ssh_remote() {
  if [ "$USE_TAILSCALE_PROXY" = "1" ]; then
    "$SSH_BIN" "${SSH_PROXY_OPTS[@]}" "$TAILSCALE_TARGET" "$@"
  else
    "$SSH_BIN" "${SSH_OPTS[@]}" "$REMOTE_HOST" "$@"
  fi
}

remote_disk_status() {
  local command='df -Pk / | awk '\''NR==2 {gsub(/%/, "", $5); print $4, $5}'\'''
  local output
  output="$("$SSH_BIN" "${SSH_OPTS[@]}" "$REMOTE_HOST" "$command" 2>/dev/null || true)"
  if [ -z "$output" ] && [ -x "$TAILSCALE_BIN" ]; then
    output="$("$SSH_BIN" "${SSH_PROXY_OPTS[@]}" "$TAILSCALE_TARGET" "$command" 2>/dev/null || true)"
  fi
  printf '%s' "$output"
}

check_remote_disk_headroom() {
  if [ "${CODEX_VPS_SKIP_REMOTE_DISK_PREFLIGHT:-0}" = "1" ]; then
    return 0
  fi

  local disk_status free_kb used_percent free_mb
  disk_status="$(remote_disk_status)"
  if [ -z "$disk_status" ]; then
    log "warning: could not check ${REMOTE_HOST} disk headroom before attach"
    return 0
  fi

  free_kb="${disk_status%% *}"
  used_percent="${disk_status##* }"
  free_mb=$((free_kb / 1024))

  if [ "$free_mb" -lt "$REMOTE_DISK_MIN_FREE_MB" ] || [ "$used_percent" -ge "$REMOTE_DISK_FAIL_USED_PERCENT" ]; then
    echo "codex-vps: refusing to attach because ${REMOTE_HOST} disk headroom is unsafe (${used_percent}% used, ${free_mb}MB free)." >&2
    echo "codex-vps: low disk has previously broken Codex rollout writes and can disconnect active sessions." >&2
    echo "codex-vps: inspect with: ssh ${REMOTE_HOST} 'df -h /; du -xhd1 ~ 2>/dev/null | sort -h | tail -n 40'" >&2
    exit 1
  fi

  if [ "$used_percent" -ge "$REMOTE_DISK_WARN_USED_PERCENT" ]; then
    log "warning: ${REMOTE_HOST} disk is ${used_percent}% used (${free_mb}MB free); low headroom can destabilize Codex sessions"
  fi
}

tailscale_check_url_from_output() {
  /usr/bin/perl -ne 'if (m#(https://login\.tailscale\.com/a/\S+)#) { print "$1\n"; exit }'
}

maybe_run_tailscale_ssh_check() {
  local output url
  if [ "${CODEX_VPS_ALLOW_TAILSCALE_SSH_CHECK:-0}" != "1" ]; then
    log "normal SSH failed; skipping Tailscale SSH browser-check fallback"
    log "set CODEX_VPS_ALLOW_TAILSCALE_SSH_CHECK=1 to explicitly use that fallback"
    return 1
  fi

  output="$(timeout "${SSH_PROBE_TIMEOUT}s" "$SSH_BIN" -vv -o BatchMode=yes -o "ConnectTimeout=${SSH_CONNECT_TIMEOUT}" -o ConnectionAttempts=1 -o ControlMaster=no -o ControlPath=none -o ControlPersist=no -o StrictHostKeyChecking=accept-new "$TAILSCALE_TARGET" true 2>&1 || true)"
  url="$(printf '%s\n' "$output" | tailscale_check_url_from_output)"
  if [ -z "$url" ] && ! printf '%s\n' "$output" | grep -qi 'Tailscale SSH requires an additional check'; then
    return 1
  fi

  echo "codex-vps: Tailscale SSH needs a browser approval check." >&2
  if [ -n "$url" ]; then
    echo "codex-vps: opening ${url}" >&2
    /usr/bin/open "$url" >/dev/null 2>&1 || true
  else
    echo "codex-vps: run: ssh ${TAILSCALE_TARGET} true" >&2
  fi
  echo "codex-vps: after approving it, run codex-vps again." >&2
  return 2
}

select_ssh_transport() {
  local tailscale_check_status
  if [ "${CODEX_VPS_USE_TAILSCALE_PROXY:-0}" != "1" ] \
    && timeout "${SSH_PROBE_TIMEOUT}s" "$SSH_BIN" "${SSH_OPTS[@]}" "$REMOTE_HOST" true >/dev/null 2>&1; then
    USE_TAILSCALE_PROXY=0
    log "using normal SSH transport"
    return 0
  fi

  if maybe_run_tailscale_ssh_check; then
    tailscale_check_status=0
  else
    tailscale_check_status="$?"
  fi
  case "$tailscale_check_status" in
    2) return 1 ;;
  esac

  if [ -x "$TAILSCALE_BIN" ] \
    && timeout "${SSH_PROBE_TIMEOUT}s" "$SSH_BIN" "${SSH_PROXY_OPTS[@]}" "$TAILSCALE_TARGET" true >/dev/null 2>&1; then
    USE_TAILSCALE_PROXY=1
    log "using Tailscale userspace SSH transport"
    return 0
  fi

  if timeout "${SSH_PROBE_TIMEOUT}s" "$SSH_BIN" "${SSH_OPTS[@]}" "$REMOTE_HOST" true >/dev/null 2>&1; then
    USE_TAILSCALE_PROXY=0
    log "Tailscale userspace SSH unavailable; using normal SSH transport"
    return 0
  fi

  echo "codex-vps: cannot reach ${REMOTE_HOST} over normal SSH or Tailscale userspace SSH" >&2
  return 1
}

remote_codex_version() {
  local app_version remote_codex
  app_version="$(app_server_codex_version 2>/dev/null || true)"
  if [ -n "$app_version" ]; then
    printf '%s\n' "$app_version"
    return 0
  fi
  remote_codex="$(printf '%q' "$REMOTE_RELEASE_CODEX")"
  ssh_remote "${remote_codex} --version" 2>/dev/null | awk '{print $2}'
}

app_server_codex_version() {
  python3 - "$REMOTE_URL" <<'PY'
import asyncio
import json
import re
import sys
import websockets

async def main():
    async with websockets.connect(sys.argv[1]) as ws:
        await ws.send(json.dumps({
            "jsonrpc": "2.0",
            "id": 1,
            "method": "initialize",
            "params": {
                "clientInfo": {"name": "codex-vps-version", "version": "1"},
                "protocolVersion": "2025-05-19",
            },
        }))
        while True:
            message = json.loads(await asyncio.wait_for(ws.recv(), timeout=8))
            if message.get("id") != 1:
                continue
            user_agent = ((message.get("result") or {}).get("userAgent") or "")
            match = re.search(r"/([0-9]+(?:\.[0-9]+){2}(?:[-.a-zA-Z0-9]+)?)", user_agent)
            if match:
                print(match.group(1))
            return

asyncio.run(main())
PY
}

is_valid_codex_version() {
  local pattern='^[0-9]+\.[0-9]+\.[0-9]+([-.][A-Za-z0-9.-]+)?$'
  [[ "${1:-}" =~ $pattern ]]
}

capture_remote_version_snapshot() {
  local observed
  if [ -n "$REMOTE_VERSION_SNAPSHOT" ]; then
    return 0
  fi

  observed="$(remote_codex_version)"
  if ! is_valid_codex_version "$observed"; then
    echo "codex-vps: could not determine remote Codex version on ${REMOTE_HOST}" >&2
    return 1
  fi
  REMOTE_VERSION_SNAPSHOT="$observed"
}

verify_remote_version_snapshot() {
  local observed
  if [ -z "$REMOTE_VERSION_SNAPSHOT" ]; then
    echo "codex-vps: remote Codex version snapshot is missing" >&2
    return 1
  fi

  observed="$(app_server_codex_version 2>/dev/null || true)"
  if ! is_valid_codex_version "$observed"; then
    echo "codex-vps: established transport did not return an app-server version" >&2
    return 1
  fi
  if [ "$observed" != "$REMOTE_VERSION_SNAPSHOT" ]; then
    echo "codex-vps: remote app-server version changed during transport setup (selected ${REMOTE_VERSION_SNAPSHOT}, established ${observed}); rerun codex-vps" >&2
    return 1
  fi
}

verify_existing_rpc_transport() {
  local listener_pids
  if [ "$USE_DIRECT_TAILSCALE_APP_SERVER" = "1" ]; then
    if ! direct_tailscale_app_server_available; then
      echo "codex-vps: direct app-server transport is no longer healthy" >&2
      return 1
    fi
  else
    if ! known_helper_tunnel_listener_ok; then
      listener_pids="$(tunnel_listener_pids || true)"
      if [ -n "$listener_pids" ]; then
        log "refusing listener on 127.0.0.1:${LOCAL_PORT}; it is not an active tunnel with exact codex-vps provenance (PID(s): ${(j:,:)${(f)listener_pids}})"
      fi
      echo "codex-vps: no healthy verified app-server transport is available; --check does not create or repair a tunnel" >&2
      return 1
    fi
    if ! tunnel_health_ok; then
      echo "codex-vps: the verified existing app-server tunnel is unhealthy; --check does not repair it" >&2
      return 1
    fi
  fi
  verify_remote_version_snapshot
}

remote_doctor_json() {
  local remote_cli
  remote_cli="$(printf '%q' "$REMOTE_RELEASE_CLI")"
  ssh_remote "${remote_cli} doctor --json"
}

validate_remote_doctor_json() {
  /usr/bin/python3 -c '
import json
import sys

def fail(message):
    print(f"codex-vps: remote doctor not ready: {message}", file=sys.stderr)
    raise SystemExit(1)

try:
    report = json.load(sys.stdin)
except Exception as error:
    fail(f"invalid JSON ({error})")

if not isinstance(report, dict):
    fail("report is not an object")
if report.get("ready") is not True:
    fail(str(report.get("summary") or "doctor reported not ready"))

if "activationBarrierClear" not in report:
    fail("activation barrier state is missing")
if report.get("activationBarrierClear") is not True:
    fail("activation barrier is active or unconfirmed")
if report.get("activationBarrier") is not False:
    fail("activation barrier report is inconsistent")

app_servers = report.get("appServers")
if not isinstance(app_servers, list) or not app_servers:
    fail("no app-server acknowledgement evidence")
not_ready = [
    str(entry.get("pid", "unknown") if isinstance(entry, dict) else "unknown")
    for entry in app_servers
    if not isinstance(entry, dict) or entry.get("hotSwapReady") is not True
]
if not_ready:
    fail("app-server acknowledgement missing for pid(s): " + ",".join(not_ready))

processes = report.get("processes")
if not isinstance(processes, list):
    fail("process acknowledgement list is missing")
not_ready = [
    str(entry.get("pid", "unknown") if isinstance(entry, dict) else "unknown")
    for entry in processes
    if not isinstance(entry, dict) or entry.get("hotSwapReady") is not True
]
if not_ready:
    fail("runtime acknowledgement missing for pid(s): " + ",".join(not_ready))

print(report.get("summary") or "ready with verified runtime acknowledgements")
'
}

require_remote_doctor_readiness() {
  local doctor_json doctor_summary
  if ! doctor_json="$(remote_doctor_json 2>/dev/null)"; then
    echo "codex-vps: remote doctor --json could not be read from the current release" >&2
    return 1
  fi
  if ! doctor_summary="$(printf '%s' "$doctor_json" | validate_remote_doctor_json)"; then
    return 1
  fi
  printf '%s' "$doctor_summary"
}

select_matching_local_remote_client() {
  local remote_version="$1"
  local candidate candidate_version
  for candidate in "$NPM_REMOTE_CLIENT" "$APP_BUNDLED_CLIENT" "$PATCHED_REMOTE_CLIENT" "$LOCAL_CLIENT"; do
    candidate_version=""
    if [ -x "$candidate" ]; then
      candidate_version="$(codex_version "$candidate")"
    fi
    if [ "$candidate_version" = "$remote_version" ]; then
      LOCAL_CLIENT="$candidate"
      LOCAL_CLIENT_VERSION_SNAPSHOT="$candidate_version"
      return 0
    fi
  done
  return 1
}

require_matching_local_remote_client() {
  local remote_version local_version
  capture_remote_version_snapshot || return $?
  remote_version="$REMOTE_VERSION_SNAPSHOT"

  if ! select_matching_local_remote_client "$remote_version"; then
    local_version="$(codex_version "$LOCAL_CLIENT")"
    echo "codex-vps: local remote client ${local_version:-missing} does not match remote ${remote_version}" >&2
    echo "codex-vps: run 'codex-vps sync-client' to install the matching client explicitly" >&2
    return 1
  fi
}

sync_local_remote_client() {
  local command_name="${1:-}"
  local remote_version
  if [ "$command_name" != "sync-client" ]; then
    echo "codex-vps: client synchronization is only available through 'codex-vps sync-client'" >&2
    return 2
  fi

  capture_remote_version_snapshot || return $?
  remote_version="$REMOTE_VERSION_SNAPSHOT"
  if select_matching_local_remote_client "$remote_version"; then
    echo "codex-vps client already matches remote ${remote_version}: ${LOCAL_CLIENT}"
    return 0
  fi

  log "installing Mac Codex remote client ${remote_version} to match ${REMOTE_HOST}..."
  mkdir -p "$LOCAL_CLIENT_ROOT"
  (
    cd "$LOCAL_CLIENT_ROOT"
    if [ ! -f package.json ]; then
      npm init -y >/dev/null
    fi
    npm install "@openai/codex@${remote_version}" --omit=dev --no-audit --no-fund >/dev/null
  )
  if ! select_matching_local_remote_client "$remote_version"; then
    echo "codex-vps: installed client still does not match remote ${remote_version}" >&2
    return 1
  fi
  echo "codex-vps client synchronized: ${LOCAL_CLIENT} (${remote_version})"
}

tunnel_process_evidence_ok() {
  local owner_pid supervisor_pid ssh_pid
  owner_pid="$(tunnel_metadata_value owner_pid 2>/dev/null || true)"
  supervisor_pid="$(tunnel_metadata_value supervisor_pid 2>/dev/null || true)"
  ssh_pid="$(tunnel_metadata_value ssh_pid 2>/dev/null || true)"
  is_positive_integer "$owner_pid" && is_positive_integer "$supervisor_pid" && is_positive_integer "$ssh_pid" || return 1
  metadata_process_evidence_matches owner "$owner_pid" || return 1
  metadata_process_evidence_matches supervisor "$supervisor_pid" || return 1
  metadata_process_evidence_matches ssh "$ssh_pid"
}

verified_recorded_ssh_child() {
  local pid="${1:-$(tunnel_metadata_value ssh_pid 2>/dev/null || true)}"
  local supervisor_pid="${2:-$(tunnel_metadata_value supervisor_pid 2>/dev/null || true)}"
  local metadata_pid metadata_supervisor metadata_port metadata_remote_port
  local actual_parent args forward ssh_name

  metadata_pid="$(tunnel_metadata_value ssh_pid 2>/dev/null || true)"
  metadata_supervisor="$(tunnel_metadata_value supervisor_pid 2>/dev/null || true)"
  metadata_port="$(tunnel_metadata_value local_port 2>/dev/null || true)"
  metadata_remote_port="$(tunnel_metadata_value remote_port 2>/dev/null || true)"
  [ -n "$pid" ] && [ "$pid" = "$metadata_pid" ] || return 1
  [ -n "$supervisor_pid" ] && [ "$supervisor_pid" = "$metadata_supervisor" ] || return 1
  [ "$metadata_port" = "$LOCAL_PORT" ] && [ "$metadata_remote_port" = "$REMOTE_PORT" ] || return 1
  process_is_alive "$pid" || return 1

  actual_parent="$("$PS_BIN" -p "$pid" -o ppid= 2>/dev/null | tr -d '[:space:]')"
  [ "$actual_parent" = "$supervisor_pid" ] || return 1
  args="$("$PS_BIN" -p "$pid" -o args= 2>/dev/null || true)"
  forward="${LOCAL_PORT}:127.0.0.1:${REMOTE_PORT}"
  ssh_name="${SSH_BIN:t}"
  [[ "$args" == *"${ssh_name}"* && "$args" == *" -N "* && "$args" == *" -L ${forward} "* ]] || return 1
  [[ "$args" == *"${REMOTE_HOST}"* || "$args" == *"${TAILSCALE_TARGET}"* ]]
}

verified_owned_ssh_child() {
  tunnel_metadata_matches_current_owner || return 1
  tunnel_process_evidence_ok || return 1
  verified_recorded_ssh_child "$@"
}

known_helper_tunnel_metadata_ok() {
  local version helper_path owner_pid owner_token supervisor_pid ssh_pid
  local metadata_host owner_pattern supervisor_parent owner_args supervisor_args helper_name

  recorded_tunnel_owner_metadata_ok || return 1
  version="$(tunnel_metadata_value version 2>/dev/null || true)"
  helper_path="$(tunnel_metadata_value helper_path 2>/dev/null || true)"
  owner_pid="$(tunnel_metadata_value owner_pid 2>/dev/null || true)"
  owner_token="$(tunnel_metadata_value owner_token 2>/dev/null || true)"
  supervisor_pid="$(tunnel_metadata_value supervisor_pid 2>/dev/null || true)"
  ssh_pid="$(tunnel_metadata_value ssh_pid 2>/dev/null || true)"
  metadata_host="$(tunnel_metadata_value remote_host 2>/dev/null || true)"

  [ "$version" = "3" ] && [ "$helper_path" = "$HELPER_PATH" ] || return 1
  [ "$(tunnel_metadata_value local_port 2>/dev/null || true)" = "$LOCAL_PORT" ] || return 1
  [ "$(tunnel_metadata_value remote_port 2>/dev/null || true)" = "$REMOTE_PORT" ] || return 1
  [ "$metadata_host" = "$REMOTE_HOST" ] || return 1
  is_positive_integer "$owner_pid" && is_positive_integer "$supervisor_pid" && is_positive_integer "$ssh_pid" || return 1
  [ "$owner_pid" != "$supervisor_pid" ] && [ "$owner_pid" != "$ssh_pid" ] && [ "$supervisor_pid" != "$ssh_pid" ] || return 1

  owner_pattern="^${owner_pid}-[0-9]+-[0-9]+-[0-9]+$"
  [[ "$owner_token" =~ $owner_pattern ]] || return 1
  tunnel_process_evidence_ok || return 1
  supervisor_parent="$("$PS_BIN" -p "$supervisor_pid" -o ppid= 2>/dev/null | tr -d '[:space:]')"
  [ "$supervisor_parent" = "$owner_pid" ] || return 1

  helper_name="${HELPER_PATH:t}"
  owner_args="$("$PS_BIN" -p "$owner_pid" -o args= 2>/dev/null || true)"
  supervisor_args="$("$PS_BIN" -p "$supervisor_pid" -o args= 2>/dev/null || true)"
  [[ "$owner_args" == *"${helper_name}"* && "$supervisor_args" == *"${helper_name}"* ]] || return 1
  verified_recorded_ssh_child "$ssh_pid" "$supervisor_pid"
}

known_helper_tunnel_listener_ok() {
  local expected_pid pids pid
  known_helper_tunnel_metadata_ok || return 1
  expected_pid="$(tunnel_metadata_value ssh_pid 2>/dev/null || true)"
  pids="$(tunnel_listener_pids || true)"
  [ -n "$pids" ] || return 1
  while IFS= read -r pid; do
    [ "$pid" = "$expected_pid" ] || return 1
  done <<< "$pids"
}

owned_tunnel_listener_ok() {
  local expected_pid pids pid
  expected_pid="$(tunnel_metadata_value ssh_pid 2>/dev/null || true)"
  verified_owned_ssh_child "$expected_pid" || return 1
  pids="$(tunnel_listener_pids || true)"
  [ -n "$pids" ] || return 1
  while IFS= read -r pid; do
    [ "$pid" = "$expected_pid" ] || return 1
  done <<< "$pids"
}

stop_owned_ssh_child() {
  local pid supervisor_pid attempt
  pid="$(tunnel_metadata_value ssh_pid 2>/dev/null || true)"
  supervisor_pid="$(tunnel_metadata_value supervisor_pid 2>/dev/null || true)"
  [ -n "$pid" ] || return 0
  if ! verified_owned_ssh_child "$pid" "$supervisor_pid"; then
    log "refusing to signal unverified tunnel PID ${pid}"
    return 1
  fi

  "$KILL_BIN" -TERM "$pid" 2>/dev/null || true
  for attempt in {1..10}; do
    process_is_alive "$pid" || break
    sleep_for 0.1
  done
  if process_is_alive "$pid"; then
    if ! verified_owned_ssh_child "$pid" "$supervisor_pid"; then
      log "refusing to escalate signal for reused tunnel PID ${pid}"
      return 1
    fi
    "$KILL_BIN" -KILL "$pid" 2>/dev/null || true
  fi
  wait "$pid" 2>/dev/null || true
  TUNNEL_SSH_PID=""
  write_tunnel_metadata "$supervisor_pid" ""
}

desktop_codex_host_is_running() {
  pgrep -x ChatGPT >/dev/null 2>&1 || pgrep -x Codex >/dev/null 2>&1
}

restart_codex_desktop_remote_bridge() {
  if ! desktop_codex_host_is_running; then
    return 0
  fi

  local pids
  pids="$(pgrep -f "$DESKTOP_REMOTE_PROXY_PATTERN" 2>/dev/null || true)"
  if [ -z "$pids" ]; then
    log "ChatGPT/Codex desktop remote bridge proxy is not running"
    return 0
  fi

  log "restarting ChatGPT/Codex desktop remote bridge..."
  printf '%s\n' "$pids" | while IFS= read -r pid; do
    [ -n "$pid" ] || continue
    kill -TERM "$pid" 2>/dev/null || true
  done
  sleep_for 1

  pids="$(pgrep -f "$DESKTOP_REMOTE_PROXY_PATTERN" 2>/dev/null || true)"
  if [ -n "$pids" ]; then
    printf '%s\n' "$pids" | while IFS= read -r pid; do
      [ -n "$pid" ] || continue
      kill -KILL "$pid" 2>/dev/null || true
    done
  fi
}

tunnel_health_ok() {
  "$CURL_BIN" -fsS --max-time "$TUNNEL_HEALTH_TIMEOUT_SECONDS" "$HEALTH_URL" >/dev/null 2>&1
}

spawn_tunnel_ssh_child() {
  local supervisor_pid target
  supervisor_pid="$(current_process_pid)"
  refuse_unknown_tunnel_listener || return 1

  if [ "$USE_TAILSCALE_PROXY" = "1" ]; then
    target="$TAILSCALE_TARGET"
    log "opening Tailscale userspace SSH tunnel 127.0.0.1:${LOCAL_PORT} -> ${TAILSCALE_HOST}:127.0.0.1:${REMOTE_PORT}"
    "$SSH_BIN" "${TUNNEL_SSH_PROXY_OPTS[@]}" -N -o ExitOnForwardFailure=yes -L ${LOCAL_PORT}:127.0.0.1:${REMOTE_PORT} "$target" &
  else
    target="$REMOTE_HOST"
    log "opening SSH tunnel 127.0.0.1:${LOCAL_PORT} -> ${REMOTE_HOST}:127.0.0.1:${REMOTE_PORT}"
    "$SSH_BIN" "${TUNNEL_SSH_OPTS[@]}" -N -o ExitOnForwardFailure=yes -L ${LOCAL_PORT}:127.0.0.1:${REMOTE_PORT} "$target" &
  fi
  TUNNEL_SSH_PID="$!"
  write_tunnel_metadata "$supervisor_pid" "$TUNNEL_SSH_PID"
}

tunnel_supervisor_cleanup() {
  local exit_code="$?"
  trap - EXIT INT TERM HUP
  stop_owned_ssh_child || true
  return "$exit_code"
}

run_tunnel_supervisor() {
  local health_failures=0
  local retry_attempt=0
  local first_spawn=1
  local iterations=0
  local delay child_status

  TUNNEL_SUPERVISOR_PID="$(current_process_pid)"
  write_tunnel_metadata "$TUNNEL_SUPERVISOR_PID" ""
  trap tunnel_supervisor_cleanup EXIT
  trap 'exit 130' INT
  trap 'exit 143' TERM
  trap 'exit 129' HUP

  while true; do
    iterations=$((iterations + 1))
    if [ "$TUNNEL_SUPERVISOR_MAX_ITERATIONS" -gt 0 ] && [ "$iterations" -gt "$TUNNEL_SUPERVISOR_MAX_ITERATIONS" ]; then
      return 0
    fi

    if [ -z "$TUNNEL_SSH_PID" ] || ! process_is_alive "$TUNNEL_SSH_PID"; then
      if [ -n "$TUNNEL_SSH_PID" ]; then
        set +e
        wait "$TUNNEL_SSH_PID" 2>/dev/null
        child_status="$?"
        set -e
        log "SSH tunnel child ${TUNNEL_SSH_PID} exited with status ${child_status}"
        TUNNEL_SSH_PID=""
        write_tunnel_metadata "$TUNNEL_SUPERVISOR_PID" ""
        if [ "$USE_TAILSCALE_PROXY" = "1" ]; then
          log "Tailscale userspace SSH tunnel failed; falling back to normal SSH tunnel"
          USE_TAILSCALE_PROXY=0
        fi
      fi

      refuse_unknown_tunnel_listener || return 1
      if [ "$first_spawn" = "0" ]; then
        retry_attempt=$((retry_attempt + 1))
        delay="$(reconnect_delay_for_attempt "$retry_attempt" "$TUNNEL_RECONNECT_DELAY" "$TUNNEL_RECONNECT_DELAY_MAX")"
        log "retrying SSH tunnel in ${delay}s (attempt ${retry_attempt})"
        sleep_for "$delay"
      fi
      first_spawn=0
      spawn_tunnel_ssh_child || return 1
      health_failures=0
    fi

    if owned_tunnel_listener_ok && tunnel_health_ok; then
      health_failures=0
      retry_attempt=0
    else
      if [ -n "$(tunnel_listener_pids || true)" ] && ! owned_tunnel_listener_ok; then
        log "an unknown listener appeared on 127.0.0.1:${LOCAL_PORT}; refusing to replace it"
        return 1
      fi
      health_failures=$((health_failures + 1))
      if [ "$health_failures" -lt "$TUNNEL_HEALTH_FAILURE_LIMIT" ]; then
        log "SSH tunnel health probe failed (${health_failures}/${TUNNEL_HEALTH_FAILURE_LIMIT}); keeping owned child open"
      else
        log "owned SSH tunnel is unhealthy after ${health_failures} failed probes; reconnecting"
        stop_owned_ssh_child || return 1
        health_failures=0
      fi
    fi
    sleep_for "$TUNNEL_HEALTH_INTERVAL_SECONDS"
  done
}

start_tunnel_supervisor_for_interactive_attach() {
  if [ -n "$TUNNEL_SUPERVISOR_PID" ] && process_is_alive "$TUNNEL_SUPERVISOR_PID"; then
    wait_for_health
    return $?
  fi
  refuse_unknown_tunnel_listener || return 1
  if [ "$TUNNEL_LOCK_HELD" != "1" ] || ! tunnel_metadata_matches_current_owner; then
    acquire_tunnel_lock || return 1
  fi
  run_tunnel_supervisor &
  TUNNEL_SUPERVISOR_PID="$!"
  if ! wait_for_health; then
    log "SSH tunnel did not become ready within ${TUNNEL_STARTUP_TIMEOUT_SECONDS}s"
    return 1
  fi
}

cleanup_tunnel_supervisor() {
  local exit_code="$?"
  local child_cleanup_ok=1
  [ "$TUNNEL_CLEANUP_ACTIVE" = "0" ] || return "$exit_code"
  TUNNEL_CLEANUP_ACTIVE=1
  trap - EXIT INT TERM HUP
  if [ -n "$TUNNEL_SUPERVISOR_PID" ] && process_is_alive "$TUNNEL_SUPERVISOR_PID"; then
    if tunnel_metadata_matches_current_owner \
      && [ "$(tunnel_metadata_value supervisor_pid 2>/dev/null || true)" = "$TUNNEL_SUPERVISOR_PID" ] \
      && metadata_process_evidence_matches supervisor "$TUNNEL_SUPERVISOR_PID"; then
      "$KILL_BIN" -TERM "$TUNNEL_SUPERVISOR_PID" 2>/dev/null || true
      wait "$TUNNEL_SUPERVISOR_PID" 2>/dev/null || true
    else
      log "refusing to signal unverified tunnel supervisor PID ${TUNNEL_SUPERVISOR_PID}"
      child_cleanup_ok=0
    fi
  fi
  stop_owned_ssh_child || child_cleanup_ok=0
  if [ "$child_cleanup_ok" = "1" ]; then
    release_tunnel_lock || true
  else
    log "warning: retaining tunnel ownership lock because the recorded SSH child could not be verified"
  fi
  TUNNEL_SUPERVISOR_PID=""
  TUNNEL_CLEANUP_ACTIVE=0
  return "$exit_code"
}

direct_tailscale_app_server_available() {
  [ "${CODEX_VPS_FORCE_TUNNEL:-0}" != "1" ] && "$CURL_BIN" -fsS --max-time 8 "$DIRECT_HEALTH_URL" >/dev/null 2>&1
}

ensure_local_remote_client_for_direct() {
  if [ -x "$APP_BUNDLED_CLIENT" ]; then
    LOCAL_CLIENT="$APP_BUNDLED_CLIENT"
  elif [ -x "$NPM_REMOTE_CLIENT" ]; then
    LOCAL_CLIENT="$NPM_REMOTE_CLIENT"
  elif [ -x "$PATCHED_REMOTE_CLIENT" ]; then
    LOCAL_CLIENT="$PATCHED_REMOTE_CLIENT"
  elif command -v codex >/dev/null 2>&1; then
    LOCAL_CLIENT="$(command -v codex)"
  else
    echo "codex-vps: no local Codex client available for direct app-server attach" >&2
    exit 1
  fi
}

wait_for_health() {
  local waited=0
  while [ "$waited" -lt "$TUNNEL_STARTUP_TIMEOUT_SECONDS" ]; do
    if owned_tunnel_listener_ok && tunnel_health_ok; then
      return 0
    fi
    if [ -n "$TUNNEL_SUPERVISOR_PID" ] && ! process_is_alive "$TUNNEL_SUPERVISOR_PID"; then
      return 1
    fi
    sleep_for 1
    waited=$((waited + 1))
  done
  return 1
}

ensure_tunnel() {
  start_tunnel_supervisor_for_interactive_attach
}

ensure_rpc_transport() {
  if [ "$USE_DIRECT_TAILSCALE_APP_SERVER" != "1" ]; then
    ensure_tunnel
  fi
}

codex_vps_thread_rpc() {
  CODEX_VPS_REMOTE_REPO="$REMOTE_REPO" python3 - "$REMOTE_URL" "$@" <<'PY'
import asyncio
import datetime as dt
import json
import os
import sys
import textwrap
import websockets

uri = sys.argv[1]
remote_repo = os.environ["CODEX_VPS_REMOTE_REPO"]
command = sys.argv[2] if len(sys.argv) > 2 else "list"
args = sys.argv[3:]

async def request(ws, request_id, method, params=None):
    payload = {"jsonrpc": "2.0", "id": request_id, "method": method}
    if params is not None:
        payload["params"] = params
    await ws.send(json.dumps(payload))
    while True:
        message = json.loads(await asyncio.wait_for(ws.recv(), timeout=20))
        if message.get("id") != request_id:
            continue
        if "error" in message:
            raise SystemExit(f"{method} failed: {message['error'].get('message') or message['error']}")
        return message.get("result") or {}

def source_label(source):
    if isinstance(source, str):
        return source
    if isinstance(source, dict):
        if "root" in source:
            return str(source.get("root"))
        if "subAgent" in source:
            return "subAgent"
        return ",".join(source.keys()) or "unknown"
    return "unknown"

def format_time(value):
    try:
        return dt.datetime.fromtimestamp(int(value), dt.UTC).strftime("%m-%d %H:%M")
    except Exception:
        return "-"

def short(text, width):
    text = " ".join((text or "").split())
    return textwrap.shorten(text, width=width, placeholder="…") if text else "-"

async def main():
    async with websockets.connect(uri, max_size=64 * 1024 * 1024) as ws:
        await request(ws, 1, "initialize", {
            "clientInfo": {"name": "codex-vps", "version": "1"},
            "protocolVersion": "2025-05-19",
        })
        if command == "list":
            default_id = args[0] if args else ""
            result = await request(ws, 2, "thread/list", {
                "limit": 80,
                "sortKey": "updated_at",
                "sourceKinds": ["cli", "vscode", "appServer", "exec", "unknown"],
            })
            rows = result.get("data") or []
            print(f"{'*':1} {'updated':11} {'source':9} {'cwd':28} {'thread id':36}  name / preview")
            for row in rows:
                thread_id = row.get("id") or row.get("sessionId") or ""
                marker = "*" if thread_id == default_id else " "
                cwd = short(row.get("cwd"), 28)
                label = row.get("name") or row.get("title") or row.get("preview")
                print(f"{marker:1} {format_time(row.get('updatedAt')):11} {source_label(row.get('source'))[:9]:9} {cwd:28} {thread_id:36}  {short(label, 90)}")
            return
        if command == "new":
            params = {"cwd": remote_repo}
            if len(args) > 0 and args[0]:
                params["model"] = args[0]
            result = await request(ws, 2, "thread/start", params)
            thread = result.get("thread") or {}
            thread_id = thread.get("id") or thread.get("sessionId")
            if not thread_id:
                raise SystemExit("thread/start did not return a thread id")
            print(thread_id)
            return
        if command == "archive":
            if not args or not args[0]:
                raise SystemExit("usage: codex-vps archive <thread-id>")
            await request(ws, 2, "thread/archive", {"threadId": args[0]})
            print(f"archived {args[0]}")
            return
        raise SystemExit(f"unknown thread rpc command: {command}")

asyncio.run(main())
PY
}

restart_remote_codex() {
  if [ -n "$(tunnel_listener_pids || true)" ] && ! owned_tunnel_listener_ok; then
    refuse_unknown_tunnel_listener
    return 1
  fi
  log "restarting port-${REMOTE_PORT} Codex app-server on ${REMOTE_HOST}..."
  ssh_remote "systemctl --user restart ${SERVICE_NAME}"
  ensure_tunnel
  restart_codex_desktop_remote_bridge
  echo "codex-vps restarted: local 127.0.0.1:${LOCAL_PORT} -> ${REMOTE_HOST}:127.0.0.1:${REMOTE_PORT}"
  echo "codex-vps note: ChatGPT's built-in SSH Unix-socket worker is separate and was not verified by this restart."
}

codex_vps_main() {
trap cleanup_tunnel_supervisor EXIT
trap 'exit 130' INT
trap 'exit 143' TERM
trap 'exit 129' HUP
validate_runtime_config || return $?
validate_thread_command_args "$@" || return $?

case "${1:-}" in
  help|-h|--help)
    print_usage
    return 0
    ;;
  use)
    persist_default_thread_id "$2"
    echo "codex-vps default thread set to $2"
    return 0
    ;;
  old|legacy)
    persist_default_thread_id "$DEFAULT_THREAD_ID"
    echo "codex-vps default thread set to $DEFAULT_THREAD_ID"
    return 0
    ;;
esac

log "checking ${REMOTE_HOST} app-server..."
if [ "${CODEX_VPS_FORCE_TUNNEL:-0}" != "1" ] && direct_tailscale_app_server_available; then
  USE_DIRECT_TAILSCALE_APP_SERVER=1
  REMOTE_URL="$DIRECT_REMOTE_URL"
  log "using direct Tailscale app-server ${DIRECT_REMOTE_URL}"
else
  if [ "${1:-}" != "--check" ]; then
    refuse_unknown_tunnel_listener
  fi
  select_ssh_transport
fi

if [ "${1:-}" = "start" ]; then
  log "starting port-${REMOTE_PORT} Codex app-server on ${REMOTE_HOST}..."
  ssh_remote "systemctl --user start ${SERVICE_NAME}"
  echo "codex-vps started ${SERVICE_NAME}"
  return 0
fi

if [ "${1:-}" = "--restart" ] || [ "${1:-}" = "restart" ]; then
  restart_remote_codex
  return 0
fi

if [ "${1:-}" = "sync-client" ]; then
  sync_local_remote_client "$1"
  return $?
fi

case "${1:-}" in
  --check|list|threads) ;;
  *) check_remote_disk_headroom ;;
esac

case "${1:-}" in
  list|threads)
    ensure_rpc_transport
    codex_vps_thread_rpc list "$THREAD_ID"
    exit 0
    ;;
  create)
    ensure_rpc_transport
    NEW_THREAD_ID="$(codex_vps_thread_rpc new "$(codex_launch_model)")"
    require_valid_thread_id "$NEW_THREAD_ID" "new thread id returned by app-server"
    persist_default_thread_id "$NEW_THREAD_ID"
    echo "codex-vps new default thread: ${NEW_THREAD_ID}"
    exit 0
    ;;
  new|reset)
    ensure_rpc_transport
    log "starting a fresh remote Codex thread..."
    NEW_THREAD_ID="$(codex_vps_thread_rpc new "$(codex_launch_model)")"
    require_valid_thread_id "$NEW_THREAD_ID" "new thread id returned by app-server"
    persist_default_thread_id "$NEW_THREAD_ID"
    THREAD_ID="$NEW_THREAD_ID"
    log "new default thread ${THREAD_ID}"
    shift
    ;;
  resume)
    if [ -z "${2:-}" ]; then
      echo "usage: codex-vps resume <thread-id>" >&2
      exit 2
    fi
    THREAD_ID="$2"
    persist_default_thread_id "$THREAD_ID"
    shift 2
    ;;
  archive)
    ensure_rpc_transport
    codex_vps_thread_rpc archive "${2:-}"
    exit 0
    ;;
esac

RESTART_AND_CONNECT=0
if [ "${1:-}" = "--restart-connect" ] || [ "${1:-}" = "restart-connect" ]; then
  restart_remote_codex
  RESTART_AND_CONNECT=1
fi

if [ "${1:-}" = "--remote-client" ]; then
  shift
  USE_REMOTE_CLIENT=1
elif [ "${1:-}" = "--direct-ssh" ]; then
  shift
  USE_REMOTE_CLIENT=0
else
  USE_REMOTE_CLIENT=1
fi

if [ "${1:-}" = "--check" ] || [ "$USE_REMOTE_CLIENT" = "1" ]; then
  log "checking Codex client version..."
  require_matching_local_remote_client || return $?
fi

if [ "${1:-}" = "--check" ]; then
  local doctor_summary service_status
  if [ "$USE_DIRECT_TAILSCALE_APP_SERVER" != "1" ]; then
    service_status="$(ssh_remote "systemctl --user is-active ${SERVICE_NAME}" 2>/dev/null || true)"
    if [ "$service_status" != "active" ]; then
      echo "codex-vps: ${SERVICE_NAME} is ${service_status:-unavailable}; run 'codex-vps start' explicitly" >&2
      return 1
    fi
  fi
  verify_existing_rpc_transport || return $?
  doctor_summary="$(require_remote_doctor_readiness)" || return $?

  if [ "$USE_DIRECT_TAILSCALE_APP_SERVER" = "1" ]; then
    echo "codex-vps ready: direct ${DIRECT_REMOTE_URL}"
  else
    echo "codex-vps ready: existing local 127.0.0.1:${LOCAL_PORT} -> ${REMOTE_HOST}:127.0.0.1:${REMOTE_PORT}"
  fi
  echo "codex-vps doctor: ${doctor_summary}"
  echo "codex-vps versions: Mac remote client ${LOCAL_CLIENT_VERSION_SNAPSHOT} == VPS app-server ${REMOTE_VERSION_SNAPSHOT}"
  echo "codex-vps client path: $LOCAL_CLIENT"
  echo "codex-vps model config: model=$(codex_launch_model) reasoning=$(codex_launch_reasoning_effort)"
  echo "codex-vps permissions: $(codex_launch_permission_summary)"
  if [ "$USE_DIRECT_TAILSCALE_APP_SERVER" = "1" ]; then
    echo "codex-vps SSH tunnel fallback: not checked on direct path"
  else
    echo "codex-vps SSH tunnel fallback: ready"
  fi
  exit 0
fi

if [ "$USE_REMOTE_CLIENT" != "1" ]; then
  log "connecting over direct SSH TTY fallback..."
  REMOTE_CODEX_ARGS="$(codex_remote_shell_config_args)"
  REMOTE_SSH_COMMAND="$(direct_ssh_session_command "$REMOTE_CODEX_ARGS")"
  if [ "$USE_TAILSCALE_PROXY" = "1" ]; then
    exec "$SSH_BIN" -tt "${SSH_PROXY_OPTS[@]}" "$TAILSCALE_TARGET" "$REMOTE_SSH_COMMAND"
  fi
  exec "$SSH_BIN" -tt "${SSH_OPTS[@]}" "$REMOTE_HOST" "$REMOTE_SSH_COMMAND"
fi

if [ "$USE_DIRECT_TAILSCALE_APP_SERVER" != "1" ]; then
  start_tunnel_supervisor_for_interactive_attach
fi
verify_remote_version_snapshot || return $?

cd "$LOCAL_REPO"
if [ "$RESTART_AND_CONNECT" = "1" ]; then
  shift
fi

log "connecting to remote Codex session via ${REMOTE_URL}..."
CODEX_ARGS=("${(@f)$(codex_launch_config_args)}")

run_remote_client_once() {
  if [ -n "${CODEX_VPS_USE_PTY_BRIDGE:-}" ]; then
    env TERM=xterm-256color "$PTY_BRIDGE" -- "$LOCAL_CLIENT" "${CODEX_ARGS[@]}" --remote "$REMOTE_URL" resume "$THREAD_ID"
  else
    "$LOCAL_CLIENT" "${CODEX_ARGS[@]}" --remote "$REMOTE_URL" resume "$THREAD_ID"
  fi
}

if [ "$REMOTE_CLIENT_AUTO_RECONNECT" != "1" ]; then
  local remote_client_status=0
  run_remote_client_once || remote_client_status=$?
  cleanup_tunnel_supervisor
  return "$remote_client_status"
fi

remote_client_attempt=0
while true; do
  set +e
  run_remote_client_once
  remote_client_status="$?"
  set -e

  case "$remote_client_status" in
    0|130|143)
      exit "$remote_client_status"
      ;;
  esac

  remote_client_attempt=$((remote_client_attempt + 1))
  if [ "$REMOTE_CLIENT_RECONNECT_MAX" -gt 0 ] && [ "$remote_client_attempt" -gt "$REMOTE_CLIENT_RECONNECT_MAX" ]; then
    log "remote Codex client exited with status ${remote_client_status}; reconnect limit reached"
    exit "$remote_client_status"
  fi

  remote_client_delay="$(reconnect_delay_for_attempt "$remote_client_attempt" "$REMOTE_CLIENT_RECONNECT_DELAY" "$REMOTE_CLIENT_RECONNECT_DELAY_MAX")"
  log "remote Codex client exited with status ${remote_client_status}; reconnecting in ${remote_client_delay}s..."
  if [ "$USE_DIRECT_TAILSCALE_APP_SERVER" != "1" ]; then
    ensure_rpc_transport || exit 1
  fi
  verify_remote_version_snapshot || exit 1
  sleep_for "$remote_client_delay"
done
}

if [ "${CODEX_VPS_SOURCE_ONLY:-0}" != "1" ]; then
  codex_vps_main "$@"
fi
